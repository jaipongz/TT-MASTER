    private async findActiveDraftById(id: string): Promise<{{EntityName}}Draft | null> {
        return this.draftRepository
            .createQueryBuilder('d')
            .where('d.objStatus = :status', { status: 'active' })
            .andWhere('(d.{{camelName}}Id = :id OR d.objContentId = :id)', { id })
            .orderBy('d.objRev', 'DESC')
            .getOne()
    }

