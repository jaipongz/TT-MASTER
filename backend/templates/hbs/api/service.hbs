                normalized['{{this.name}}'].map((item: unknown) => String(item ?? '').trim()).filter(Boolean),
            )
        }
{{/if}}
{{#if this.isBoolean}}
        if (typeof normalized['{{this.name}}'] === 'boolean') {
            normalized['{{this.name}}'] = normalized['{{this.name}}'] ? 1 : 0
        } else if (normalized['{{this.name}}'] !== undefined && normalized['{{this.name}}'] !== null) {
            const raw = String(normalized['{{this.name}}']).trim().toLowerCase()
            normalized['{{this.name}}'] = raw === '1' || raw === 'true' || raw === 'yes' || raw === 'on' ? 1 : 0
        }
{{/if}}
{{#if this.isImage}}
        if (normalized['{{this.name}}_gen'] === undefined || normalized['{{this.name}}_gen'] === null) {
            normalized['{{this.name}}_gen'] = normalized['{{this.name}}'] ? 'N' : ''
        }
{{/if}}
{{#if this.isVideo}}
        if (normalized['{{this.name}}_gen'] === undefined || normalized['{{this.name}}_gen'] === null) {
            normalized['{{this.name}}_gen'] = normalized['{{this.name}}'] ? 'N' : ''
        }
{{/if}}
{{#if this.isFile}}
        if (normalized['{{this.name}}_gen'] === undefined || normalized['{{this.name}}_gen'] === null) {
            normalized['{{this.name}}_gen'] = normalized['{{this.name}}'] ? 'N' : ''
        }
{{/if}}
{{#if this.isFulltext}}
        if (normalized['{{this.name}}_plain'] === undefined || normalized['{{this.name}}_plain'] === null) {
            const plainSource = String(normalized['{{this.name}}'] ?? '')
            normalized['{{this.name}}_plain'] = plainSource.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim()
        }
{{/if}}
{{/each}}

        return normalized
    }

