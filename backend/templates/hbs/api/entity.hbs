import { Column, CreateDateColumn, Entity, PrimaryColumn } from 'typeorm';

@Entity('{{fileName}}')
export class {{EntityName}} {
  @PrimaryColumn({ type: 'bigint', name: '{{fileName}}_id' })
  {{camelName}}Id: string;

{{#each fieldList}}
  @Column('{{this.columnType}}', { name: '{{this.name}}'{{this.nullableText}} })
  {{this.propertyName}}{{#unless this.required}}?{{/unless}}: {{#if this.isBoolean}}number{{else}}{{#if this.isArray}}string{{else}}{{this.dtoType}}{{/if}}{{/if}};

{{/each}}
  @Column('varchar', { name: 'obj_lang', length: 10 })
  objLang: string;

  @Column('bigint', { name: 'obj_content_id' })
  objContentId: string;

  @CreateDateColumn({ name: 'obj_created_date' })
  objCreatedDate: Date;

  @Column('int', { name: 'obj_created_by' })
  objCreatedBy: number;

  @Column('datetime', { name: 'obj_published_date', nullable: true, default: () => 'NULL' })
  objPublishedDate: Date | null;

  @Column('int', { name: 'obj_published_by', nullable: true })
  objPublishedBy: number | null;
}
